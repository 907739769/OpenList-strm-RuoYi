# Build stage
FROM node:20-alpine AS build

WORKDIR /app

# Copy from openlist-web directory
COPY openlist-web/package*.json ./
RUN npm install --production=false

COPY openlist-web/ .
RUN npm run build

# Production stage
FROM nginx:alpine

# Copy built files
COPY --from=build /app/dist /usr/share/nginx/html

# Copy nginx config from build context root
COPY nginx.conf /etc/nginx/conf.d/default.conf

EXPOSE 80

CMD ["nginx", "-g", "daemon off;"]
