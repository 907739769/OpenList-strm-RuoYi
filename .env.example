# MySQL 配置
MYSQL_ROOT_PASSWORD=your_secure_root_password_here
MYSQL_DATABASE=osr

# 应用专用数据库账号（非 root，仅拥有 MYSQL_DATABASE 库的权限，由 MySQL 镜像自动创建）
DB_USERNAME=osr_app
DB_PASSWORD=your_secure_app_db_password_here

# JWT 密钥（至少256位/32字符，请替换为强随机字符串）
JWT_SECRET=your-secure-jwt-secret-key-at-least-32-characters-long-here

# 时区
TZ=Asia/Shanghai

# 允许跨域访问的前端来源，逗号分隔。
# 生产环境由 Nginx 同源代理 /api，通常无需配置；
# 若前后端分域部署或直连后端 API，需显式指定（如 http://your-domain:80）。
# CORS_ALLOWED_ORIGINS=http://your-domain:80
