FROM eclipse-temurin:21-jre-alpine

WORKDIR /app

COPY ruoyi-admin/target/ruoyi-admin.jar /app/

# Create required directories with proper permissions
RUN mkdir -p /data/upload /data/logs /data/strm && chmod -R 777 /data

EXPOSE 6895

ENTRYPOINT ["java", "-Djava.security.egd=file:/dev/./urandom", "-jar", "/app/ruoyi-admin.jar"]
